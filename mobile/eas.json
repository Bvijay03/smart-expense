{
  "cli": {
    "version": ">= 20.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "development-local": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
        "distribution": "internal",
        "env": {
          "EXPO_PUBLIC_API_URL": "https://smart-expense-api-16xp.onrender.com/api/v1"
        },
        "android": {
          "buildType": "apk"
        }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
